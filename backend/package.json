{
  "name": "airport-semey-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for Semey airport portal",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "prestart:dev": "node -e \"require('fs').mkdirSync('uploads/services',{recursive:true})\"",
    "lint": "echo \"No linter configured yet\"",
    "db:generate": "drizzle-kit generate",
